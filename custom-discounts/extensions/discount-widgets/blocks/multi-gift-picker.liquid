{% comment %}Multi-Gift Picker Widget — ORDER_VALUE_MULTI_PICK. Reads gift products from metafield automatically.{% endcomment %}
{% if block.settings.enabled %}
{% assign metafield_config = shop.metafields.custom_discounts.free_gift_config.value %}
<style>
#mgp-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9997;backdrop-filter:blur(2px)}
#mgp-panel{display:none;position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);z-index:9999;background:#fff;border-radius:20px;box-shadow:0 24px 80px rgba(0,0,0,.22);width:min(96vw,560px);max-height:88vh;overflow-y:auto;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
#mgp-head{position:sticky;top:0;background:#fff;border-bottom:1px solid #f0f0f3;padding:18px 20px 14px;border-radius:20px 20px 0 0;z-index:1}
#mgp-hr{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:10px}
#mgp-title{font-size:17px;font-weight:800;color:#111827}
#mgp-x{background:#f3f4f6;border:none;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;flex-shrink:0}
#mgp-x:hover{background:#e5e7eb}
#mgp-pill{display:inline-block;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;border-radius:20px;padding:3px 12px;font-size:12px;font-weight:700;transition:background .3s;margin-bottom:8px}
#mgp-pill.done{background:linear-gradient(135deg,#16a34a,#4ade80)}
#mgp-pw{height:5px;background:#e5e7eb;border-radius:10px;overflow:hidden}
#mgp-pf{height:100%;background:linear-gradient(90deg,#7c3aed,#a78bfa);border-radius:10px;transition:width .4s}
#mgp-msg{font-size:12px;color:#9ca3af;margin-top:5px}
#mgp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(145px,1fr));gap:12px;padding:16px 20px 18px}
.mgp-card{border:2px solid #e5e7eb;border-radius:14px;padding:12px;text-align:center;cursor:pointer;transition:border-color .2s,box-shadow .2s,transform .18s;background:#fafafa;position:relative;user-select:none}
.mgp-card:hover:not(.mgp-dis){border-color:#7c3aed;box-shadow:0 4px 18px rgba(124,58,237,.14);transform:translateY(-2px)}
.mgp-card.mgp-sel{border-color:#7c3aed;background:#f5f3ff}
.mgp-card.mgp-dis{opacity:.45;cursor:not-allowed}
.mgp-ck{position:absolute;top:-8px;right:-8px;width:22px;height:22px;background:#7c3aed;border-radius:50%;display:none;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:700}
.mgp-card.mgp-sel .mgp-ck{display:flex}
.mgp-card img{width:82px;height:82px;object-fit:cover;border-radius:10px;margin-bottom:7px;display:block;margin-left:auto;margin-right:auto}
.mgp-ph{width:82px;height:82px;background:#e5e7eb;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 7px}
.mgp-name{font-size:11px;font-weight:600;color:#374151;line-height:1.3;min-height:26px;margin-bottom:7px}
.mgp-cb{width:100%;padding:6px;border-radius:8px;border:none;font-size:12px;font-weight:600;cursor:pointer;background:#7c3aed;color:#fff;transition:background .2s}
.mgp-cb.rm{background:#f3f4f6;color:#374151}
.mgp-cb.rm:hover{background:#e5e7eb}
#mgp-confirm{margin:0 20px 20px}
#mgp-ok{width:100%;padding:12px;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;transition:opacity .2s}
#mgp-ok:disabled{opacity:.45;cursor:default}
#mgp-trig{position:fixed;bottom:22px;right:22px;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;border:none;border-radius:50px;padding:12px 20px;font-size:13px;font-weight:700;cursor:pointer;box-shadow:0 6px 26px rgba(124,58,237,.42);display:none;align-items:center;gap:8px;z-index:9998}
#mgp-tbadge{background:#fff;color:#7c3aed;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800}
</style>
<div id="mgp-ov"></div>
<div id="mgp-panel">
  <div id="mgp-head">
    <div id="mgp-hr"><div id="mgp-title">{{ block.settings.heading | escape }}</div><button id="mgp-x">&#x2715;</button></div>
    <div id="mgp-pill">0 / 0</div>
    <div id="mgp-pw"><div id="mgp-pf" style="width:0%"></div></div>
    <div id="mgp-msg"></div>
  </div>
  <div id="mgp-grid"></div>
  <div id="mgp-confirm"><button id="mgp-ok" disabled>Select gifts to continue</button></div>
</div>
<button id="mgp-trig">🎁 <span id="mgp-tlbl">Choose Free Gifts</span><span id="mgp-tbadge">0</span></button>
<script>
(function(){
  var cfg={{ metafield_config | json }};
  if(!cfg||cfg.configType!=='ORDER_VALUE_MULTI_PICK')return;
  if(!cfg.minimumSpend||!cfg.giftVariantIds||!cfg.maxGifts)return;
  var MAX=parseInt(cfg.maxGifts),MIN=cfg.minimumSpend*100,PROP='_custom_multi_gift',CUR='{{ cart.currency.symbol }}';
  var giftOpts=cfg.giftOptions||[];
  var ov=document.getElementById('mgp-ov'),panel=document.getElementById('mgp-panel'),xBtn=document.getElementById('mgp-x');
  var pill=document.getElementById('mgp-pill'),pf=document.getElementById('mgp-pf'),msg=document.getElementById('mgp-msg');
  var ok=document.getElementById('mgp-ok'),trig=document.getElementById('mgp-trig'),tlbl=document.getElementById('mgp-tlbl'),tbadge=document.getElementById('mgp-tbadge');
  var grid=document.getElementById('mgp-grid');
  var sel=new Map(),busy=false,panelOpen=false,qualifies=false,seen=false;

  // Build gift cards from enriched giftOptions
  function buildCards(){
    var opts=giftOpts.length?giftOpts:cfg.giftVariantIds.map(function(id){return{numericId:id.replace('gid://shopify/ProductVariant/',''),title:'Gift Option',imageUrl:null,variantTitle:null}});
    opts.forEach(function(opt){
      var img=opt.imageUrl?'<img src="'+opt.imageUrl+'" alt="'+opt.title+'" loading="lazy">':'<div class="mgp-ph">🎁</div>';
      var name=opt.title+(opt.variantTitle?' — '+opt.variantTitle:'');
      var d=document.createElement('div');d.className='mgp-card';d.dataset.vid=opt.numericId;
      d.innerHTML='<div class="mgp-ck">✓</div>'+img+'<div class="mgp-name">'+name+'</div><button class="mgp-cb">+ Select</button>';
      d.addEventListener('click',function(){if(busy)return;var v=parseInt(d.dataset.vid);if(sel.has(v)){sel.delete(v)}else{if(sel.size>=MAX)return;sel.set(v,1)}syncUI()});
      grid.appendChild(d);
    });
  }

  function openPanel(){ov.style.display='block';panel.style.display='block';panelOpen=true;trig.style.display='none';seen=true;document.body.style.overflow='hidden'}
  function closePanel(){ov.style.display='none';panel.style.display='none';panelOpen=false;document.body.style.overflow='';if(qualifies)trig.style.display='flex'}
  ov.onclick=xBtn.onclick=closePanel;trig.onclick=openPanel;

  function syncUI(){
    var n=sel.size;
    pill.textContent=n+' / '+MAX;pill.classList.toggle('done',n>=MAX);
    tbadge.textContent=n;tlbl.textContent=n>=MAX?'Gifts Ready!':'Pick '+(MAX-n)+' more';
    ok.disabled=n===0;ok.textContent=n===0?'Select gifts to continue':(n<MAX?'Confirm '+n+' Gift'+(n>1?'s':'')+' (pick '+MAX+' total)':'✓ Confirm '+n+' Free Gift'+(n>1?'s':''));
    document.querySelectorAll('.mgp-card').forEach(function(c){
      var v=parseInt(c.dataset.vid),s=sel.has(v),b=c.querySelector('.mgp-cb');
      c.classList.toggle('mgp-sel',s);c.classList.toggle('mgp-dis',!s&&n>=MAX);
      b.textContent=s?'✓ Remove':'+ Select';b.className='mgp-cb'+(s?' rm':'');
    });
  }

  ok.addEventListener('click',async function(){
    if(busy||sel.size===0)return;busy=true;ok.disabled=true;ok.textContent='Applying…';
    try{
      var r=await fetch('/cart.js',{cache:'no-store'}),cart=await r.json();
      var ex=cart.items.filter(function(i){return i.properties&&i.properties[PROP]==='true'});
      for(var g of ex){if(!sel.has(g.variant_id))await fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:g.key,quantity:0})})}
      var exIds=new Set(ex.map(function(g){return g.variant_id}));
      var toAdd=[...sel.keys()].filter(function(id){return !exIds.has(id)});
      if(toAdd.length)await fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:toAdd.map(function(id){return{id:id,quantity:1,properties:{[PROP]:'true','_hidden':'true'}}})})});
      closePanel();window.dispatchEvent(new Event('cart:updated'));setTimeout(function(){location.reload()},400);
    }catch(e){console.error(e);busy=false;syncUI()}
  });

  async function evalCart(){
    try{
      var r=await fetch('/cart.js',{cache:'no-store'}),cart=await r.json();
      var sub=0,gids=[];
      cart.items.forEach(function(i){if(i.properties&&i.properties[PROP]==='true'){gids.push(i.variant_id)}else{sub+=i.original_line_price||i.line_price}});
      qualifies=sub>=MIN;pf.style.width=Math.min(100,Math.round(sub/MIN*100))+'%';
      if(!qualifies){
        msg.textContent='Spend '+CUR+((MIN-sub)/100).toFixed(2)+' more for free gifts';
        closePanel();trig.style.display='none';
        var exG=cart.items.filter(function(i){return i.properties&&i.properties[PROP]==='true'});
        if(exG.length){for(var g of exG)await fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:g.key,quantity:0})});location.reload()}
        return;
      }
      sel.clear();gids.forEach(function(id){sel.set(id,1)});
      msg.textContent=sel.size>=MAX?'✓ '+MAX+' gift'+(MAX>1?'s ':' ')+'selected!':'🎉 Pick '+MAX+' free gift'+(MAX>1?'s':'')+'!';
      syncUI();if(!seen){openPanel()}else{trig.style.display='flex'}
    }catch(e){console.error(e)}
  }
  var t;function deb(){clearTimeout(t);t=setTimeout(evalCart,900)}
  buildCards();
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',evalCart)}else{evalCart()}
  var _f=window.fetch;window.fetch=async function(){var res=await _f.apply(this,arguments);var u=typeof arguments[0]==='string'?arguments[0]:(arguments[0]?.url||'');if(u.includes('/cart')&&!u.includes('/cart.js'))deb();return res};
})();
</script>
{% endif %}
{% schema %}
{
  "name": "Multi-Gift Picker Widget",
  "target": "body",
  "settings": [
    {"type":"checkbox","id":"enabled","label":"Enable Multi-Gift Picker","default":true},
    {"type":"text","id":"heading","label":"Heading","default":"🎁 Choose Your Free Gifts!"}
  ]
}
{% endschema %}
