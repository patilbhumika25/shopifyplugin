{% comment %}
  Auto-Add Free Gift (App Embed Block)
  Automatically adds free gift(s) to the customer's cart when they reach order value thresholds.
  Now supports multiple active offers.
{% endcomment %}

{% if block.settings.enable_auto_add %}
  {% assign metafield_config = shop.metafields.custom_discounts.free_gift_config.value %}
  <script>
    (function() {
      const rawConfigs = {{ metafield_config | json }};
      const ALL_CONFIGS = Array.isArray(rawConfigs) ? rawConfigs : (rawConfigs && Object.keys(rawConfigs).length > 0 ? [rawConfigs] : []);
      
      if (ALL_CONFIGS.length === 0) {
        console.log('[Auto-Gift] No active free gift offers. Exiting.');
        return;
      }

      function parseConfig(raw) {
        const c = {
          offerId: raw.offerId || 'unknown',
          configType: raw.configType || 'BASIC',
          minSpend: (raw.minimumSpend || 0) * 100,
          minQuantity: parseInt(raw.minQuantity || 0, 10),
          giftVariantId: 0,
          triggerProductId: 0,
          giftVariantIds: [],
          tiers: [],
          startDate: raw.startDate ? new Date(raw.startDate).getTime() : null,
          endDate: raw.endDate ? new Date(raw.endDate).getTime() : null,
          propertyKey: `_custom_gift_${raw.offerId || 'auto'}`
        };

        const vMatch = (raw.giftVariantId || '').match(/ProductVariant\/(\d+)/);
        c.giftVariantId = vMatch ? parseInt(vMatch[1], 10) : parseInt(raw.giftVariantId || 0, 10);

        const tMatch = (raw.triggerProductId || '').match(/Product\/(\d+)/);
        c.triggerProductId = tMatch ? parseInt(tMatch[1], 10) : parseInt(raw.triggerProductId || 0, 10);

        if (Array.isArray(raw.giftVariantIds)) {
          c.giftVariantIds = raw.giftVariantIds.map(id => {
            const m = (id || '').match(/ProductVariant\/(\d+)/);
            return m ? parseInt(m[1], 10) : parseInt(id, 10);
          }).filter(id => !isNaN(id));
        }

        if (Array.isArray(raw.tiers)) {
          c.tiers = raw.tiers.map(t => {
            const m = (t.giftVariantId || '').match(/ProductVariant\/(\d+)/);
            return {
              minSpend: (t.minimumSpend || 0) * 100,
              giftVariantId: m ? parseInt(m[1], 10) : parseInt(t.giftVariantId, 10)
            };
          }).sort((a, b) => b.minSpend - a.minSpend);
        }
        return c;
      }

      const PARSED_OFFERS = ALL_CONFIGS.map(parseConfig);
      console.log(`[Auto-Gift] Loaded ${PARSED_OFFERS.length} active offer(s).`);

      let isProcessing = false;
      const RETRY_KEY = 'auto_gift_retries';
      const MAX_RETRIES = 3;

      async function evaluateCart() {
        if (isProcessing) return;
        const retries = parseInt(sessionStorage.getItem(RETRY_KEY) || '0');
        if (retries >= MAX_RETRIES) return;
        
        try {
          isProcessing = true;
          const res = await fetch('/cart.js', { cache: 'no-store' });
          const cart = await res.json();

          const updates = { add: [], change: {} };
          let needsReload = false;

          for (const CONFIG of PARSED_OFFERS) {
            let subtotal = 0;
            let giftQty = 0;
            let giftKey = null;
            let triggerInCart = false;
            let hasSub = false;

            cart.items.forEach(item => {
              if (item.properties && item.properties[CONFIG.propertyKey] === 'true') {
                giftQty = item.quantity;
                giftKey = item.key;
              } else {
                subtotal += item.original_line_price || item.line_price;
                if (item.product_id === CONFIG.triggerProductId) triggerInCart = true;
                if (item.selling_plan_allocation) hasSub = true;
              }
            });

            let qualifies = false;
            let targetId = CONFIG.giftVariantId;

            switch (CONFIG.configType) {
              case 'PRODUCT_PURCHASE': qualifies = triggerInCart; break;
              case 'SUBSCRIPTION':
              case 'SUBSCRIPTION_FIRST': qualifies = hasSub; break;
              case 'TIME_LIMITED':
                const now = Date.now();
                qualifies = (!CONFIG.startDate || now >= CONFIG.startDate) && (!CONFIG.endDate || now <= CONFIG.endDate) && subtotal >= CONFIG.minSpend;
                break;
              case 'MYSTERY':
                let totalQty = cart.items.reduce((s, i) => s + (i.properties?.[CONFIG.propertyKey] === 'true' ? 0 : i.quantity), 0);
                qualifies = totalQty >= CONFIG.minQuantity && CONFIG.giftVariantIds.length > 0;
                if (qualifies && giftQty === 0) targetId = CONFIG.giftVariantIds[Math.floor(Math.random() * CONFIG.giftVariantIds.length)];
                break;
              case 'ORDER_VALUE_CHOICE':
                const tier = CONFIG.tiers.find(t => subtotal >= t.minSpend);
                if (tier) { qualifies = true; targetId = tier.giftVariantId; }
                break;
              default: qualifies = subtotal >= CONFIG.minSpend && CONFIG.minSpend > 0;
            }

            if (qualifies && giftQty === 0 && targetId) {
              updates.add.push({ id: targetId, quantity: 1, properties: { [CONFIG.propertyKey]: 'true', '_hidden': 'true' } });
              needsReload = true;
            } else if (qualifies && giftQty > 1) {
              updates.change[giftKey] = 1;
              needsReload = true;
            } else if (!qualifies && giftQty > 0) {
              updates.change[giftKey] = 0;
              needsReload = true;
            }
          }

          if (needsReload) {
            if (updates.add.length > 0) {
              await fetch('/cart/add.js', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ items: updates.add }) });
            }
            for (const [key, qty] of Object.entries(updates.change)) {
              await fetch('/cart/change.js', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: key, quantity: qty }) });
            }
            sessionStorage.setItem(RETRY_KEY, (retries + 1).toString());
            location.reload();
          } else {
            sessionStorage.setItem(RETRY_KEY, '0');
          }
        } catch (e) {
          console.error('[Auto-Gift] Error:', e);
        } finally {
          isProcessing = false;
        }
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', evaluateCart);
      else evaluateCart();

      let timeout = null;
      function debounced() { if (timeout) clearTimeout(timeout); timeout = setTimeout(evaluateCart, 1000); }

      const originalFetch = window.fetch;
      window.fetch = async function() {
        const response = await originalFetch.apply(this, arguments);
        const url = typeof arguments[0] === 'string' ? arguments[0] : (arguments[0]?.url || '');
        if (url.includes('/cart') && !url.includes('/cart.js')) debounced();
        return response;
      };
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Auto-Add Free Gift",
  "target": "body",
  "settings": [
    { "type": "checkbox", "id": "enable_auto_add", "label": "Enable Auto-Add Gift", "default": true }
  ]
}
{% endschema %}
