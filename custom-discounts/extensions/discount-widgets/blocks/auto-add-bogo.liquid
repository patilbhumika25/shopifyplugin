{% comment %}
  Auto-Add BOGO Gift (App Embed Block)
  Automatically adds the "Get" product to the cart when "Buy" requirements are met.
  Now supports multiple active BOGO/Combo offers.
{% endcomment %}

{% if block.settings.enable_bogo_auto_add %}
  {% assign metafield_config = shop.metafields.custom_discounts.bogo_config.value %}
  <script>
    (function() {
      const rawConfigs = {{ metafield_config | json }};
      const ALL_CONFIGS = Array.isArray(rawConfigs) ? rawConfigs : (rawConfigs && Object.keys(rawConfigs).length > 0 ? [rawConfigs] : []);
      
      if (ALL_CONFIGS.length === 0) {
        console.log('[Auto-BOGO] No active BOGO offers. Exiting.');
        return;
      }

      function parseConfig(raw) {
        const c = {
          offerId: raw.offerId || 'unknown',
          configType: raw.configType,
          buyVariantIds: [],
          eligibleProductIds: [],
          eligibleVariantIds: [],
          buyProductIds: [],
          getProductIds: [],
          bundleProductIds: [],
          getVariantId: null,
          buyQuantity: 1,
          getQuantity: 1,
          propertyKey: `_custom_bogo_${raw.offerId || 'auto'}`
        };

        const giftId = raw.getVariantId || raw.giftVariantId || '';
        const mGet = giftId.match(/ProductVariant\/(\d+)/);
        c.getVariantId = mGet ? parseInt(mGet[1], 10) : parseInt(giftId, 10);

        if (Array.isArray(raw.buyVariantIds)) {
          c.buyVariantIds = raw.buyVariantIds.map(id => {
            const m = (id || '').match(/ProductVariant\/(\d+)/);
            return m ? parseInt(m[1], 10) : parseInt(id, 10);
          }).filter(id => !isNaN(id));
        }
        if (Array.isArray(raw.buyProductIds)) {
          c.buyProductIds = raw.buyProductIds.map(id => {
            const m = (id || '').match(/Product\/(\d+)/);
            return m ? parseInt(m[1], 10) : parseInt(id, 10);
          }).filter(id => !isNaN(id));
        }
        if (Array.isArray(raw.bundleProductIds)) {
          c.bundleProductIds = raw.bundleProductIds.map(id => {
            const m = (id || '').match(/Product\/(\d+)/);
            return m ? parseInt(m[1], 10) : parseInt(id, 10);
          }).filter(id => !isNaN(id));
        }

        c.buyQuantity = parseInt(raw.buyQuantity || raw.bundleQuantity || 1, 10);
        c.getQuantity = parseInt(raw.getQuantity || 1, 10);
        
        return c;
      }

      const PARSED_OFFERS = ALL_CONFIGS.map(parseConfig);
      console.log(`[Auto-BOGO] Loaded ${PARSED_OFFERS.length} active offer(s).`);

      let isProcessing = false;
      const RETRY_KEY = 'auto_bogo_retries';
      const MAX_RETRIES = 3;

      async function evaluateCart() {
        if (isProcessing) return;
        const retries = parseInt(sessionStorage.getItem(RETRY_KEY) || '0');
        if (retries >= MAX_RETRIES) return;
        
        try {
          isProcessing = true;
          const res = await fetch('/cart.js', { cache: 'no-store' });
          const cart = await res.json();

          const updates = { add: [], change: {} };
          let needsUpdate = false;

          for (const CONFIG of PARSED_OFFERS) {
            let buyItemsCount = 0;
            let giftQty = 0;
            let giftKey = null;

            cart.items.forEach(item => {
              if (item.properties && item.properties[CONFIG.propertyKey] === 'true') {
                giftQty = item.quantity;
                giftKey = item.key;
              } else {
                let isBuy = false;
                if (CONFIG.configType === 'BUNDLE_PRICE_GIFT' && CONFIG.bundleProductIds.length > 0) {
                  isBuy = CONFIG.bundleProductIds.includes(item.product_id);
                } else if (CONFIG.buyVariantIds.length > 0) {
                  isBuy = CONFIG.buyVariantIds.includes(item.variant_id);
                } else if (CONFIG.buyProductIds.length > 0) {
                  isBuy = CONFIG.buyProductIds.includes(item.product_id);
                } else {
                  isBuy = (item.variant_id !== CONFIG.getVariantId);
                }
                if (isBuy) buyItemsCount += item.quantity;
              }
            });

            const timesTriggered = Math.floor(buyItemsCount / CONFIG.buyQuantity);
            const targetQty = timesTriggered * CONFIG.getQuantity;

            if (targetQty > giftQty && CONFIG.getVariantId) {
              updates.add.push({ id: CONFIG.getVariantId, quantity: targetQty - giftQty, properties: { [CONFIG.propertyKey]: 'true', '_hidden': 'true' } });
              needsUpdate = true;
            } else if (targetQty < giftQty && giftKey) {
              updates.change[giftKey] = targetQty;
              needsUpdate = true;
            }
          }

          if (needsUpdate) {
            if (updates.add.length > 0) {
              await fetch('/cart/add.js', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ items: updates.add }) });
            }
            for (const [key, qty] of Object.entries(updates.change)) {
              await fetch('/cart/change.js', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ id: key, quantity: qty }) });
            }
            sessionStorage.setItem(RETRY_KEY, (retries + 1).toString());
            location.reload();
          } else {
            sessionStorage.setItem(RETRY_KEY, '0');
          }
        } catch (e) {
          console.error('[Auto-BOGO] Error:', e);
        } finally {
          isProcessing = false;
        }
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', evaluateCart);
      else evaluateCart();

      let timeout = null;
      function debounced() { if (timeout) clearTimeout(timeout); timeout = setTimeout(evaluateCart, 1000); }

      const originalFetch = window.fetch;
      window.fetch = async function() {
        const response = await originalFetch.apply(this, arguments);
        const url = typeof arguments[0] === 'string' ? arguments[0] : (arguments[1]?.url || arguments[0]?.url || '');
        if (url.includes('/cart') && !url.includes('/cart.js')) debounced();
        return response;
      };
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Auto-Add BOGO Gift",
  "target": "body",
  "settings": [
    { "type": "checkbox", "id": "enable_bogo_auto_add", "label": "Enable BOGO Auto-Add", "default": true }
  ]
}
{% endschema %}
